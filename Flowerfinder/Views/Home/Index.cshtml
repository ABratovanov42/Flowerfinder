@* ---------- Species marquee ---------- *@
<div class="species-marquee" aria-hidden="true">
    <div class="marquee-track">
        <span>Rose</span><i>&middot;</i><span>Peony</span><i>&middot;</i><span>Cosmos</span><i>&middot;</i><span>Lavender</span><i>&middot;</i><span>Tulip</span><i>&middot;</i><span>Orchid</span><i>&middot;</i><span>Dahlia</span><i>&middot;</i><span>Sunflower</span><i>&middot;</i><span>Magnolia</span><i>&middot;</i><span>Jasmine</span><i>&middot;</i><span>Iris</span><i>&middot;</i><span>Camellia</span><i>&middot;</i>
        <span>Rose</span><i>&middot;</i><span>Peony</span><i>&middot;</i><span>Cosmos</span><i>&middot;</i><span>Lavender</span><i>&middot;</i><span>Tulip</span><i>&middot;</i><span>Orchid</span><i>&middot;</i><span>Dahlia</span><i>&middot;</i><span>Sunflower</span><i>&middot;</i><span>Magnolia</span><i>&middot;</i><span>Jasmine</span><i>&middot;</i><span>Iris</span><i>&middot;</i><span>Camellia</span><i>&middot;</i>
    </div>
</div>

@* ---------- Features ---------- *@
<section class="features" id="features">
    <div class="section-kicker reveal">How it works</div>
    <h2 class="reveal">Helping your garden thrive</h2>
    <div class="feature-grid">
        <div class="feature-card reveal">
            <div class="icon-ring">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                    <circle cx="12" cy="13" r="4" />
                </svg>
            </div>
            <span class="step-no">01</span>
            <h3>Identify in a snap</h3>
            <p>Point your camera at any bloom and get its name in seconds &mdash; no botany degree required.</p>
        </div>
        <div class="feature-card reveal">
            <div class="icon-ring">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22 V10" />
                    <path d="M12 12 C12 8 8 5 4 5 C4 9 8 12 12 12 Z" />
                    <path d="M12 10 C12 6 16 3 20 3 C20 7 16 10 12 10 Z" />
                </svg>
            </div>
            <span class="step-no">02</span>
            <h3>Grow with confidence</h3>
            <p>Light, water, soil and season &mdash; clear care guides tailored to each flower you find.</p>
        </div>
        <div class="feature-card reveal">
            <div class="icon-ring">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                </svg>
            </div>
            <span class="step-no">03</span>
            <h3>Uncover the story</h3>
            <p>The folklore, meaning and history behind every species &mdash; because flowers carry stories.</p>
        </div>
    </div>
</section>

@* ---------- In bloom right now ---------- *@
@if (blooming.Count > 0)
{
    <section class="blooming" id="blooming">
        <div class="section-kicker reveal">In bloom right now</div>
        <h2 class="reveal">@season.Label() flowers at their best</h2>
        <div class="bloom-wrap reveal">
            <button class="bloom-arrow prev" id="bloomPrev" type="button" aria-label="Scroll back">&larr;</button>
            <div class="bloom-row" id="bloomRow">
                @foreach (var f in blooming)
                {
                    <a class="flower-card" asp-controller="Flowers" asp-action="Details" asp-route-id="@f.Id">
                        @if (!string.IsNullOrWhiteSpace(f.ImagePath))
                        {
                            <div class="photo-frame">
                                <img class="card-photo" src="@f.ImagePath" alt="@f.CommonName" loading="lazy" />
                                <span class="view-hint">View &rarr;</span>
                            </div>
                        }
                        <h3>@f.CommonName</h3>
                        <div class="sci">@f.ScientificName</div>
                    </a>
                }
            </div>
            <button class="bloom-arrow next" id="bloomNext" type="button" aria-label="Scroll forward">&rarr;</button>
        </div>
        <div class="browse-all reveal">
            <a class="btn-ghost" asp-controller="Flowers" asp-action="Index">Browse the whole catalog</a>
        </div>
    </section>
}

@* ---------- This month in the garden ---------- *@
@if (monthTasks.Count > 0)
{
    <section class="month-garden" id="thisMonth">
        @if (ViewData["HasGarden"] as bool? == true)
        {
            <div class="section-kicker reveal">Your garden</div>
            <h2 class="reveal">Your garden in @monthName</h2>
            <p class="month-lede reveal">What the flowers you grow are asking for right now. Add or remove flowers from any flower's page.</p>
        }
        else
        {
            <div class="section-kicker reveal">The gardener's month</div>
            <h2 class="reveal">@monthName in the garden</h2>
            <p class="month-lede reveal">What your flowers are asking for right now &mdash; straight from our growing guides. Tip: mark the flowers you grow with <em>Add to my garden</em> and this becomes your personal to-do list.</p>
        }
        <div class="task-grid">
            @foreach (var t in monthTasks)
            {
                <a class="task-row reveal" asp-controller="Flowers" asp-action="Details" asp-route-id="@t.Flower.Id">
                    @if (!string.IsNullOrWhiteSpace(t.Flower.ImagePath))
                    {
                        <img class="task-thumb" src="@t.Flower.ImagePath" alt="" loading="lazy" />
                    }
                    <div class="task-copy">
                        <div class="task-name">@t.Flower.CommonName</div>
                        <div class="task-what">@t.Task</div>
                    </div>
                    <span class="task-arr" aria-hidden="true">&rarr;</span>
                </a>
            }
        </div>
    </section>
}

@* ---------- Closing ---------- *@
<section class="closing">
    <svg class="sprig reveal" viewBox="0 0 60 40" fill="none" stroke="#c9688f" stroke-width="1.6" stroke-linecap="round">
        <path d="M30 38 C30 24 30 14 30 6" />
        <path d="M30 20 C24 16 18 15 13 17 C17 23 24 24 30 22" />
        <path d="M30 14 C36 10 42 9 47 11 C43 17 36 18 30 16" />
        <circle cx="30" cy="5" r="3" />
    </svg>
    <h2 class="reveal">Bring a little more bloom into your day.</h2>
    <a class="btn-bloom reveal" asp-controller="Identify" asp-action="Index">Start identifying&nbsp;<span class="arr">&rarr;</span></a>
</section>

@section Scripts {
    <script src="~/lib/gsap/gsap.min.js"></script>
    <script src="~/lib/gsap/ScrollTrigger.min.js"></script>
    <script src="~/js/home.js" asp-append-version="true"></script>
}
