<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Flowerfinder</title>
    <meta name="description" content="Flowerfinder — snap a photo to learn any flower's name, how to help it flourish, and the story behind it." />
    <meta property="og:title" content="Flowerfinder — Every flower has a story" />
    <meta property="og:description" content="Snap a photo to learn any flower's name, how to help it flourish, and the story behind it." />
    <meta property="og:type" content="website" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌸</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,450;0,9..144,550;1,9..144,450;1,9..144,550&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Flowerfinder.styles.css" asp-append-version="true" />
    <script>
        // theme: honour the saved choice (or the OS) before first paint
        try {
            var ffTheme = localStorage.getItem("ffTheme");
            if (ffTheme === "dark" || (!ffTheme && matchMedia("(prefers-color-scheme: dark)").matches)) {
                document.documentElement.classList.add("dark");
            }
        } catch (e) { }
        // flower cursor: on unless the visitor switched it off (button in the nav)
        try {
            if (localStorage.getItem("ffCursor") !== "off" && matchMedia("(pointer: fine)").matches) {
                document.documentElement.classList.add("flower-cursor");
            }
        } catch (e) { }
        // seasonal accent: the site's rose tint follows the real season
        // (see the [data-season] blocks in site.css)
        try {
            var ffMonth = new Date().getMonth() + 1;
            document.documentElement.dataset.season =
                ffMonth >= 3 && ffMonth <= 5 ? "spring" :
                ffMonth >= 6 && ffMonth <= 8 ? "summer" :
                ffMonth >= 9 && ffMonth <= 11 ? "autumn" : "winter";
        } catch (e) { }
        // first visit this session: show the blooming loader (skipped for reduced motion)
        try {
            if (!sessionStorage.getItem("ffSeen") && !matchMedia("(prefers-reduced-motion: reduce)").matches) {
                document.documentElement.classList.add("ff-loading");
            }
        } catch (e) { }
    </script>
</head>
<body>
    @{
        var navController = ViewContext.RouteData.Values["controller"]?.ToString();
        var navAction = ViewContext.RouteData.Values["action"]?.ToString();
    }
    <div class="ff-loader" aria-hidden="true">
        <div style="text-align:center">
            <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg"
                 stroke="#c9688f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path class="lp" style="--r:0deg;--i:0"   d="M60 64 C52 48 52 26 60 14 C68 26 68 48 60 64" fill="#f5aecb" fill-opacity="0.55" />
                <path class="lp" style="--r:60deg;--i:1"  d="M60 64 C52 48 52 26 60 14 C68 26 68 48 60 64" fill="#f5aecb" fill-opacity="0.55" />
                <path class="lp" style="--r:120deg;--i:2" d="M60 64 C52 48 52 26 60 14 C68 26 68 48 60 64" fill="#f5aecb" fill-opacity="0.55" />
                <path class="lp" style="--r:180deg;--i:3" d="M60 64 C52 48 52 26 60 14 C68 26 68 48 60 64" fill="#f5aecb" fill-opacity="0.55" />
                <path class="lp" style="--r:240deg;--i:4" d="M60 64 C52 48 52 26 60 14 C68 26 68 48 60 64" fill="#f5aecb" fill-opacity="0.55" />
                <path class="lp" style="--r:300deg;--i:5" d="M60 64 C52 48 52 26 60 14 C68 26 68 48 60 64" fill="#f5aecb" fill-opacity="0.55" />
                <circle class="lc" cx="60" cy="64" r="7" fill="#f2cd7d" fill-opacity="0.9" />
            </svg>
            <div class="ff-loader-word">Flowerfinder</div>
        </div>
    </div>
    <header>
        <div class="ff-veil" aria-hidden="true"></div>
        <nav class="ff-nav" id="ffNav">
            <div class="ff-nav-inner">
                <a class="ff-brand" asp-area="" asp-controller="Home" asp-action="Index">Flowerfinder</a>
                <div class="ff-links-wrap">
                    <span class="ff-pill" aria-hidden="true"></span>
                    <ul class="ff-links">
                        <li><a class="@(navController == "Home" && navAction == "Index" ? "active" : null)" asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li id="ffCatalogItem"><a class="@(navController == "Flowers" && navAction != "Compare" && navAction != "Garden" ? "active" : null)" asp-area="" asp-controller="Flowers" asp-action="Index">Catalog</a></li>
                        <li><a class="@(navAction == "Compare" ? "active" : null)" asp-area="" asp-controller="Flowers" asp-action="Compare">Compare</a></li>
                        <li><a class="@(navAction == "Garden" ? "active" : null)" asp-area="" asp-controller="Flowers" asp-action="Garden">Garden</a></li>
                        <li><a class="@(navAction == "Privacy" ? "active" : null)" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    </ul>
                </div>
                <button class="ff-theme ff-search-btn" id="ffSearchBtn" type="button" aria-label="Search flowers (Ctrl+K)" title="Search — Ctrl+K">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
                        <circle cx="11" cy="11" r="6.5" />
                        <path d="M20.5 20.5l-4.8-4.8" />
                    </svg>
                </button>
                <button class="ff-theme" id="ffTheme" type="button" aria-label="Switch between light and dark theme">
                    <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="4.2" />
                        <path d="M12 2.5v2.4 M12 19.1v2.4 M2.5 12h2.4 M19.1 12h2.4 M5.3 5.3l1.7 1.7 M17 17l1.7 1.7 M18.7 5.3L17 7 M7 17l-1.7 1.7" />
                    </svg>
                    <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M20.5 14.5A8.5 8.5 0 0 1 9.5 3.5a8.5 8.5 0 1 0 11 11z" />
                    </svg>
                </button>
                <button class="ff-theme" id="ffCursor" type="button" aria-pressed="true"
                        aria-label="Toggle the flower cursor" title="Flower cursor on/off">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="2.6" />
                        <path d="M12 9.4 C10.6 7.6 10.6 4.4 12 2.8 C13.4 4.4 13.4 7.6 12 9.4" />
                        <path d="M12 9.4 C10.6 7.6 10.6 4.4 12 2.8 C13.4 4.4 13.4 7.6 12 9.4" transform="rotate(72 12 12)" />
                        <path d="M12 9.4 C10.6 7.6 10.6 4.4 12 2.8 C13.4 4.4 13.4 7.6 12 9.4" transform="rotate(144 12 12)" />
                        <path d="M12 9.4 C10.6 7.6 10.6 4.4 12 2.8 C13.4 4.4 13.4 7.6 12 9.4" transform="rotate(216 12 12)" />
                        <path d="M12 9.4 C10.6 7.6 10.6 4.4 12 2.8 C13.4 4.4 13.4 7.6 12 9.4" transform="rotate(288 12 12)" />
                    </svg>
                </button>
                <a class="ff-cta" asp-controller="Identify" asp-action="Index">Identify&nbsp;&rarr;</a>
                <button class="ff-burger" id="ffBurger" type="button" aria-label="Menu" aria-expanded="false" aria-controls="ffMobile">
                    <span></span><span></span>
                </button>
            </div>
            <div class="ff-drop" id="ffDrop">
                <div class="ff-drop-inner">
                    <div class="drop-col">
                        <div class="drop-kicker">By season</div>
                        <a asp-controller="Flowers" asp-action="Index" asp-route-season="Spring">Spring</a>
                        <a asp-controller="Flowers" asp-action="Index" asp-route-season="Summer">Summer</a>
                        <a asp-controller="Flowers" asp-action="Index" asp-route-season="Autumn">Autumn</a>
                        <a asp-controller="Flowers" asp-action="Index" asp-route-season="Winter">Winter</a>
                    </div>
                    <div class="drop-col">
                        <div class="drop-kicker">By colour</div>
                        <a asp-controller="Flowers" asp-action="Index" asp-route-color="Pink"><i class="dot" style="background:#e88ab0"></i>Pink</a>
                        <a asp-controller="Flowers" asp-action="Index" asp-route-color="Purple"><i class="dot" style="background:#9b6bb3"></i>Purple</a>
                        <a asp-controller="Flowers" asp-action="Index" asp-route-color="Yellow"><i class="dot" style="background:#e8c95a"></i>Yellow</a>
                        <a asp-controller="Flowers" asp-action="Index" asp-route-color="White"><i class="dot" style="background:#f5f0e8;border-color:rgba(61,58,53,.25)"></i>White</a>
                    </div>
                    <div class="drop-col">
                        <div class="drop-kicker">Explore</div>
                        <a asp-controller="Identify" asp-action="Index">Identify a flower &rarr;</a>
                        <a asp-controller="Flowers" asp-action="Index">Browse all flowers</a>
                        <a asp-controller="Flowers" asp-action="Compare">Compare flowers</a>
                        <a asp-controller="Flowers" asp-action="Garden">My garden</a>
                        <a asp-controller="Flowers" asp-action="Create">Add a flower</a>
                    </div>
                </div>
            </div>
            <div class="nav-fade" aria-hidden="true"></div>
        </nav>
    </header>
    <div class="ff-mobile" id="ffMobile">
        <a style="--i:0" asp-controller="Home" asp-action="Index">Home</a>
        <a style="--i:1" asp-controller="Identify" asp-action="Index">Identify</a>
        <a style="--i:2" asp-controller="Flowers" asp-action="Index">Catalog</a>
        <a style="--i:3" asp-controller="Flowers" asp-action="Compare">Compare</a>
        <a style="--i:4" asp-controller="Flowers" asp-action="Garden">My garden</a>
        <a style="--i:5" asp-controller="Flowers" asp-action="Create">Add a flower</a>
        <a style="--i:6" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
    @* ---------- Command palette (Ctrl+K) ---------- *@
    <div class="palette" id="palette" hidden role="dialog" aria-modal="true" aria-label="Search flowers">
        <div class="palette-veil" id="paletteVeil"></div>
        <div class="palette-panel">
            <input class="palette-input" id="paletteInput" type="text"
                   placeholder="Search flowers&hellip;" autocomplete="off" spellcheck="false" />
            <div class="palette-results" id="paletteResults" role="listbox"></div>
            <div class="palette-foot">
                <span><kbd>&uarr;</kbd><kbd>&darr;</kbd> navigate</span>
                <span><kbd>&crarr;</kbd> open</span>
                <span><kbd>esc</kbd> close</span>
            </div>
        </div>
    </div>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="ff-foot">
        <svg class="foot-sprig" viewBox="0 0 60 40" fill="none" stroke="#c9688f" stroke-width="1.6" stroke-linecap="round">
            <path d="M30 38 C30 24 30 14 30 6" />
            <path d="M30 20 C24 16 18 15 13 17 C17 23 24 24 30 22" />
            <path d="M30 14 C36 10 42 9 47 11 C43 17 36 18 30 16" />
            <circle cx="30" cy="5" r="3" />
        </svg>
        <div class="foot-brand">Flowerfinder</div>
        <div class="foot-links">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <a asp-controller="Flowers" asp-action="Index">Catalog</a>
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
        <div class="foot-fine">&copy; 2026 Flowerfinder &middot; Every flower has a story &middot; Photos via Wikimedia Commons</div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/nav.js" asp-append-version="true"></script>
    <script src="~/js/cursor.js" asp-append-version="true"></script>
    <script src="~/js/lightbox.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
